# Postgres (Railway provides this automatically as DATABASE_URL when you add a Postgres service)
DATABASE_URL=postgres://user:password@localhost:5432/create_your_resume

# Session
SESSION_SECRET=replace-with-a-long-random-string

# Admin login (set once, then delete this from .env and store only the hash in the DB)
ADMIN_USERNAME=maride

# Anthropic API
ANTHROPIC_API_KEY=your-key-here

# Google Sheets service account
# Paste the FULL contents of the service account JSON file as one line here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_ID=your-sheet-id-here

# Google Apps Script web app that stores the intake JSON and hands back
# the client-facing link (the same one the old admin.html tool posted to)
APPS_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec

# App
PORT=3000
NODE_ENV=development
